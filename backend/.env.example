# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=info
LOGIN_TYPE=mock

# Database Type: sqlite | mariadb | sqlserver | postgresql
DB_TYPE=sqlite

# Database connection parameters (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=
DB_NAME=cortex
DB_USER=cortex
DB_PASSWORD=

# Database URL (explicit, overrides DB_TYPE + individual fields above)
# SQLite:   sqlite:./data/cortex.db?mode=rwc
# MariaDB:  mysql://user:password@localhost:3306/cortex
# SqlServer: mssql://user:password@localhost:1433/cortex
# PostgreSQL: postgres://user:password@localhost:5432/cortex
DATABASE_URL=sqlite:./data/cortex.db?mode=rwc

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333

# JWT
JWT_SECRET=change-me-in-production

# LLM Provider (OpenAI compatible)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (optional)
ANTHROPIC_API_KEY=

# AI Models
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RERANKING_MODEL=BAAI/bge-reranker-v2-m3
AI_EMBEDDING_PORT=18321
AI_RERANKING_PORT=18322

# SSO / Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=cortex
KEYCLOAK_CLIENT_ID=cortex-backend
KEYCLOAK_CLIENT_SECRET=

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600
